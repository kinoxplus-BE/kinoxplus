# Core
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
WEB_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
# Port 5435 matches docker-compose.yml (5432-5434 are often taken by local installs)
DATABASE_URL=postgresql://kinoxplus:kinoxplus@localhost:5435/kinoxplus?schema=public

# Redis
REDIS_URL=redis://localhost:6379
CATALOG_CACHE_TTL_SEC=300
CATALOG_CACHE_TIMEOUT_MS=150

# Auth (TTLs in seconds — 86400 = 1 day for dev; production: ACCESS_TTL=900, REFRESH_TTL=2592000)
# Refresh tokens are opaque randoms hashed in Postgres, so no refresh secret is needed.
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=86400
ARGON2_MEMORY_COST=19456

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare Stream
CF_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
CF_STREAM_SIGNING_KEY_ID=
CF_STREAM_SIGNING_KEY_PEM=
CF_STREAM_PLAYBACK_BASE_URL=https://videodelivery.net
CF_STREAM_TOKEN_TTL_SEC=3600

# TMDB metadata seed (POC catalog only)
# Use the API Read Access Token from TMDB settings, not the short API key.
TMDB_READ_ACCESS_TOKEN=
TMDB_SEED_LIMIT=100
TMDB_LANGUAGE=en-US

# Cloudinary (avatars, posters)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 / S3
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kinoxplus-assets

# Payments
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# Email (Brevo)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@kinoxplus.com
BREVO_SENDER_NAME=KinoX+

# Google Sign-In (optional; POST /auth/google returns 400 if unset)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Use the SAME client_id on the mobile app so audience validation matches.
GOOGLE_CLIENT_ID=

# SMS (Termii)
TERMII_API_KEY=
TERMII_SENDER_ID=KINOXPLUS

# Push
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Observability
SENTRY_DSN=
